{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lyvox Vault Next",
  "version": "1.0.3",
  "identifier": "com.lyvox.vault.next",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../src-ui/dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: asset: http://asset.localhost; connect-src 'self' http://127.0.0.1:*"
    },
    "windows": [
      {
        "title": "Lyvox Vault Next",
        "width": 1280,
        "height": 840,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local encrypted vault",
    "longDescription": "Local-first encrypted password, notes, media, backup and sync vault."
  }
}

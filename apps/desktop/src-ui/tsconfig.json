{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "isolatedModules": true,
    "moduleResolution": "Bundler",
    "strict": true
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
